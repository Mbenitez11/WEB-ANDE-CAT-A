# ============================================================
# ANDE EXAMEN — variables de entorno
# Copiar a .env.local y completar. NO subir a git.
# ============================================================

# --- Base de datos ---
DATABASE_URL="file:./dev.db"

# --- Auth.js v5 ---
AUTH_SECRET=""                            # pnpm dlx auth secret
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"                    # dev

# --- Agente IA (Vercel AI SDK) ---
# Elegir UN provider y completar la clave correspondiente.
AI_PROVIDER="anthropic"                   # anthropic | openai | google
AI_MODEL="claude-sonnet-4-6"              # depende del provider
AI_TEMPERATURE="0.2"

ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- Embeddings (opcional, feature flag) ---
ENABLE_EMBEDDINGS="false"
EMBEDDINGS_PROVIDER="openai"              # openai | google
EMBEDDINGS_MODEL="text-embedding-3-small"

# --- Importador Obsidian ---
# Ruta absoluta a la bóveda LLM Wiki del proyecto ANDE EXAMEN.
OBSIDIAN_VAULT_PATH="G:/Mi unidad/FIUNA BROZ/ANDE EXAMEN/Agente codex/Database/Obsidian/ANDE CAT A"
# Bases auxiliares usadas por el importador (CSVs, dudas OCR, duplicados):
ANDE_DATABASE_PATH="G:/Mi unidad/FIUNA BROZ/ANDE EXAMEN/Agente codex/Database"
SIMULACROS_DATA_PATH="G:/Mi unidad/FIUNA BROZ/ANDE EXAMEN/Agente codex/simulacros-ande/api/questions-data.json"

# --- Rate limit (defaults razonables para dev) ---
RATELIMIT_LOGIN_PER_MIN="5"
RATELIMIT_AI_PER_MIN="20"

# --- Logs ---
LOG_LEVEL="info"
